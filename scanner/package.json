{
  "name": "ethfund-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Temporal-arbitrage scanner for Polymarket ETH Up/Down markets",
  "engines": { "node": ">=20" },
  "scripts": {
    "scan": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
