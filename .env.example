# ═══════════════════════════════════════════════════════════════════
# MASTER ENV REFERENCE — documents every key. Committed; holds NO real values.
# Copy values FROM here INTO:
#   • scanner/.env   → the scanner worker (Supabase service role, Resend, thresholds)
#   • root .env      → MCP servers / tooling used by Claude Code (.mcp.json)
# NEVER commit a filled file.
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# A) SCANNER  →  scanner/.env
# ───────────────────────────────────────────────────────────────────
# Polymarket data engine (the Rust CLI). Reads need no key; trading would.
POLYMARKET_CLI_BIN=../polia/polymarket-cli/target/release/polymarket
POLYMARKET_PRIVATE_KEY=            # optional; only for trading (not used in v1 read-only scanner)

# Supabase — history + alert dedup. The worker uses the SERVICE-ROLE key (server-only).
# Schema is applied to the shared 'creditline' project (ref rooclfwqvmwehaqmtflp).
# Get the service-role key from: Supabase dashboard → creditline → Project Settings → API keys.
SUPABASE_URL=https://rooclfwqvmwehaqmtflp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend — alert emails
RESEND_API_KEY=
ALERT_FROM=noreply@1upesports.org   # must be a Resend-verified sender/domain
ALERT_TO=ekinoxis.evm@gmail.com    # comma-separated for multiple recipients

# Scanner thresholds (optional — defaults shown match the spec §13)
MIN_SPREAD=0.05                    # 5% min YES/NO probability spread to alert
MIN_LIQUIDITY=5000                 # min liquidity (USDC) on the thinner market
MIN_VOLUME=20000                   # min volume (USDC) on the thinner market
MAX_BIDASK=0.02                    # max acceptable bid-ask spread on either market
SCAN_INTERVAL_MS=5000              # loop cadence
PAIRS=4H-vs-1H                     # comma-separated; v1 ships 4H-vs-1H. Others: 1H-vs-15M,15M-vs-5M
USE_CLOB=false                     # true = enrich best bid/ask via `clob book` (extra calls)

# ───────────────────────────────────────────────────────────────────
# B) TOOLING  →  root .env   (MCP servers used by Claude Code — .mcp.json)
# ───────────────────────────────────────────────────────────────────
SUPABASE_ACCESS_TOKEN=             # Supabase MCP (personal access token)
SUPABASE_PROJECT_REF=rooclfwqvmwehaqmtflp   # Supabase MCP (the 'creditline' project)
BLOCKSCOUT_PRO_API_KEY=            # optional; Blockscout MCP pro key (proapi_...)
# GitHub / Vercel MCPs use OAuth — authorize via /mcp, no token here.
